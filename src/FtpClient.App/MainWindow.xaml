<Window x:Class="FtpClient.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:FtpClient.App.Converters"
        Title="FTP 客户端"
        Width="1260"
        Height="820"
        MinWidth="1050"
        MinHeight="680"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:EntryKindConverter x:Key="EntryKindConverter"/>
        <converters:TransferStatusConverter x:Key="TransferStatusConverter"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="3" Opacity="0.09"/>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="230"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="FTP 客户端" FontSize="30" FontWeight="SemiBold"/>
                <TextBlock Text="基于 Socket 的被动模式文件传输" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Border Grid.Column="1"
                    Background="#FFF3CD"
                    CornerRadius="9"
                    Padding="12,7"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsTemporaryMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="临时模式 · 数据不会保存" Foreground="#8A6200"/>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="连接站点" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <TextBlock Text="已保存站点" Foreground="{StaticResource SecondaryTextBrush}"/>
                    <ComboBox ItemsSource="{Binding Sites}"
                              SelectedItem="{Binding SelectedSite}"
                              DisplayMemberPath="Name"
                              Height="38"
                              Margin="0,5,0,12"/>
                    <TextBlock Text="主机"/>
                    <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="用户名"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="端口"/>
                            <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="密码"/>
                    <PasswordBox x:Name="PasswordInput"
                                 PasswordChanged="PasswordInput_OnPasswordChanged"
                                 Margin="0,5,0,8"/>
                    <CheckBox Content="记住密码（Windows 加密）"
                              IsChecked="{Binding RememberPassword}"
                              Margin="1,3,0,14"/>
                    <Button Content="连接" Click="Connect_OnClick"/>
                    <Button Content="断开" Style="{StaticResource SecondaryButton}" Click="Disconnect_OnClick"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="上一级" Style="{StaticResource SecondaryButton}" Click="Parent_OnClick"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CurrentPath}"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   Margin="12,0"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="刷新" Style="{StaticResource SecondaryButton}" Click="Refresh_OnClick"/>
                            <Button Content="新建文件夹" Style="{StaticResource SecondaryButton}" Click="CreateDirectory_OnClick"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
                        <Button Content="上传" Click="Upload_OnClick"/>
                        <Button Content="下载" Click="Download_OnClick"/>
                        <Button Content="重命名" Style="{StaticResource SecondaryButton}" Click="Rename_OnClick"/>
                        <Button Content="删除" Background="#FF3B30" Click="Delete_OnClick"/>
                    </StackPanel>
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding RemoteEntries}"
                              SelectedItem="{Binding SelectedEntry}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              MouseDoubleClick="RemoteGrid_OnMouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="类型" Binding="{Binding IsDirectory, Converter={StaticResource EntryKindConverter}}" Width="90"/>
                            <DataGridTextColumn Header="大小" Binding="{Binding Size, Converter={StaticResource FileSizeConverter}}" Width="110"/>
                            <DataGridTextColumn Header="修改时间" Binding="{Binding ModifiedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="155"/>
                            <DataGridTextColumn Header="权限" Binding="{Binding Permissions}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,16,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="传输中心" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                <DataGrid Grid.Row="1"
                          x:Name="TransferGrid"
                          ItemsSource="{Binding Transfers}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="本地文件" Binding="{Binding LocalPath}" Width="2*"/>
                        <DataGridTextColumn Header="远程文件" Binding="{Binding RemotePath}" Width="2*"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status, Converter={StaticResource TransferStatusConverter}}" Width="90"/>
                        <DataGridTemplateColumn Header="进度" Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="4">
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="8"/>
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:0.0}%}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,10,0,0"
                                                   FontSize="11"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="速度" Binding="{Binding BytesPerSecond, Converter={StaticResource FileSizeConverter}, StringFormat={}{0}/s}" Width="95"/>
                        <DataGridTemplateColumn Header="操作" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="暂停" Padding="9,4" Click="PauseTransfer_OnClick"/>
                                        <Button Content="继续" Padding="9,4" Style="{StaticResource SecondaryButton}" Click="ResumeTransfer_OnClick"/>
                                        <Button Content="重试" Padding="9,4" Style="{StaticResource SecondaryButton}" Click="RetryTransfer_OnClick"/>
                                        <Button Content="取消" Padding="9,4" Background="#FF3B30" Click="CancelTransfer_OnClick"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="4,12,4,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SecondaryTextBrush}"/>
            <ProgressBar IsIndeterminate="True"
                         Width="120"
                         Height="4"
                         HorizontalAlignment="Right"
                         Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>
    </Grid>
</Window>
